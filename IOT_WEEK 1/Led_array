int LED_ARR[]={3,5,6,9,10,11};
int D=10;

int size=sizeof(LED_ARR)/sizeof(LED_ARR[0]); 

void setup() {
  for (int i=0;i<size;i++){ 
    pinMode(LED_ARR[i],OUTPUT);
  }}

void loop() {
  for (int i=0;i<size;i++){ 
    int LED_M=LED_ARR[i];
    
    for (int i=0;i<=175;i++){  // FADE IN
      analogWrite(LED_M,i);
      delay(D);
    }
    for (int i=175;i>=0;i--){  // FADE OUT
      analogWrite(LED_M,i);
      delay(D); 
    }}}



